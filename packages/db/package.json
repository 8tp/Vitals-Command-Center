{
  "name": "@vcc/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./queries": {
      "types": "./src/queries/index.ts",
      "import": "./src/queries/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -b && npm run copy-sql",
    "copy-sql": "node -e \"import('node:fs').then(fs=>{const src='src/migrations';const dst='dist/migrations';fs.mkdirSync(dst,{recursive:true});for(const f of fs.readdirSync(src)){fs.copyFileSync(src+'/'+f,dst+'/'+f);}})\"",
    "clean": "rm -rf dist *.tsbuildinfo",
    "db:migrate": "tsx src/migrate.ts"
  },
  "dependencies": {
    "@vcc/shared": "*",
    "better-sqlite3": "^11.3.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
