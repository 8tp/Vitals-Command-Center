# ============================================================================
# Vitals Command Center — environment template
# Copy this file to `.env` and fill in credentials.
# All health data stays local; only Claude API calls leave this machine.
# ============================================================================

# -- Runtime ----------------------------------------------------------------
NODE_ENV=development
API_PORT=3001
WEB_PORT=5173
LOG_LEVEL=info

# -- Storage paths ----------------------------------------------------------
# Absolute or repo-relative paths.
DB_PATH=./data/vitals.db
# Legacy Apple Health XML export (full "Export All Health Data" → export.xml).
# Optional; the preferred Apple path is the REST ingest (see APPLE_INGEST_SECRET).
APPLE_HEALTH_EXPORT_PATH=./data/apple-health-export/export.xml
BRIEFINGS_DIR=./data/briefings

# -- Multi-wearable source routing ------------------------------------------
# The Google Health API "bridge" (GOOGLE_* below) can return data for several
# physical devices at once (Fitbit, Apple HealthKit, residual WHOOP/Oura). This
# list decides which devices are taken FROM THE BRIDGE. Any device NOT listed
# here is taken from its NATIVE client instead (WHOOP OAuth / Oura PAT / Apple
# REST ingest) — a device is never populated by both paths (no double-counting).
# Comma list of: fitbit, apple, whoop, oura. Default: all four via the bridge.
GOOGLE_HEALTH_SOURCES=fitbit,apple,whoop,oura

# -- WHOOP (developer.whoop.com) — ACTIVE native adapter --------------------
# Used as the WHOOP source whenever 'whoop' is NOT in GOOGLE_HEALTH_SOURCES.
# Create an OAuth app, set redirect URI to http://localhost:3001/api/auth/whoop/callback
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=http://localhost:3001/api/auth/whoop/callback
# Where to land the user after successful OAuth. Default: web dashboard.
WHOOP_POST_AUTH_REDIRECT=http://localhost:5173/?connected=whoop
# Token storage file (refresh token auto-rotates).
WHOOP_TOKEN_FILE=./data/.whoop-tokens.json

# -- Oura (cloud.ouraring.com > Personal Access Tokens) — ACTIVE adapter -----
# Used as the Oura source whenever 'oura' is NOT in GOOGLE_HEALTH_SOURCES.
OURA_PAT=

# -- Apple Health REST ingest (iOS "Health Auto Export" app) ----------------
# Shared secret for POST /api/ingest/apple. The app must send it as either
# header `x-apple-ingest-secret: <value>` or `Authorization: Bearer <value>`.
# The route fails closed: if this is unset, every ingest request is rejected.
# Used as the Apple source whenever 'apple' is NOT in GOOGLE_HEALTH_SOURCES.
APPLE_INGEST_SECRET=

# -- Strava (https://www.strava.com/settings/api) — ACTIVE native adapter ---
# Create an API Application; set Authorization Callback Domain to localhost.
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:3001/api/auth/strava/callback
STRAVA_POST_AUTH_REDIRECT=http://localhost:5173/?connected=strava
STRAVA_TOKEN_FILE=./data/.strava-tokens.json

# -- Fitbit Air via Google Health API (console.cloud.google.com) ------------
# Also the multi-device "bridge" — see GOOGLE_HEALTH_SOURCES above.
# Enable the "Google Health API", create an OAuth Web application client, and
# add this exact redirect URI. Run as External/Testing with your own email as a
# test user (personal unverified app — no security review needed).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback
# Where to land after successful OAuth. Default: web dashboard.
GOOGLE_POST_AUTH_REDIRECT=http://localhost:5173/?connected=fitbit
# Token storage file (access token refreshes automatically).
GOOGLE_TOKEN_FILE=./data/.google-tokens.json

# -- Claude (console.anthropic.com) -----------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-6

# -- On-box AI agent runner (daily brief + /ask) ----------------------------
# The on-box runner tries providers in order and falls back on any failure
# (CLI not installed/logged-in, HTTP refused, empty output). Comma-separated.
# Default preserves current behavior: claude CLI, then codex CLI.
#   - claude        : `claude -p` CLI  (cloud model, local orchestration)
#   - codex         : `codex exec` CLI (cloud model, local orchestration)
#   - ollama        : local Ollama server      (fully on-box, no cloud)
#   - openai-compat : OpenAI-compatible server (LocalAI / LM Studio / vLLM)
# The local providers (ollama, openai-compat) keep ALL inference on-box /
# fully private — nothing leaves the machine. For a no-cloud setup use e.g.
# AI_PROVIDERS=ollama  (or a hybrid: AI_PROVIDERS=ollama,claude).
AI_PROVIDERS=claude,codex
# Optional: shared timeout for every provider (CLI + HTTP), in ms. Default 240s.
# AI_TIMEOUT_MS=240000

# Ollama (https://ollama.com) — run `ollama serve` + `ollama pull <model>`.
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1

# OpenAI-compatible server (LocalAI, LM Studio, vLLM, text-generation-webui).
# openai-compat is only used when OPENAI_COMPAT_URL is set. POSTs to
# ${OPENAI_COMPAT_URL}/v1/chat/completions. The key is optional — most local
# servers need none; leave OPENAI_COMPAT_KEY blank to omit the Authorization
# header entirely.
OPENAI_COMPAT_URL=
OPENAI_COMPAT_MODEL=
OPENAI_COMPAT_KEY=

# -- Sync schedule ----------------------------------------------------------
# Cron expression. Default: every 4 hours on the hour.
SYNC_CRON=0 */4 * * *
# Daily briefing generation: 6:00 AM local.
BRIEFING_CRON=0 6 * * *
# Weekly report: Sunday 8:00 AM.
WEEKLY_REPORT_CRON=0 8 * * 0

# -- Remote MCP server (HTTP transport + OAuth, for claude.ai web) -----------
MCP_HTTP_PORT=8787
# Public HTTPS URL once exposed via Tailscale Funnel:
# MCP_PUBLIC_URL=https://<host>.<tailnet>.ts.net
MCP_AUTH_USER=
MCP_AUTH_PASSWORD=
MCP_OAUTH_FILE=./data/.mcp-oauth.json

# -- Personal profile for AI prompts (brief, ask, MCP) ----------------------
# Injected into the AI's system prompt so advice is personalized. Keep your REAL
# profile in .env (gitignored) — never in source. Free text: goals, training,
# diet, supplements, allergies, constraints.
USER_PROFILE="Goals: general fitness and better sleep. Training: 3 runs/week. Diet: high-protein. Supplements: none. Constraints: none."
