{
  "name": "@vcc/mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "vcc-mcp": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/index.ts",
    "dev:http": "tsx watch --clear-screen=false src/http.ts",
    "build": "tsc -b",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@vcc/db": "*",
    "@vcc/shared": "*",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.7.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
